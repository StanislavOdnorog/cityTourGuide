# ===== PostgreSQL =====
POSTGRES_DB=citystories
POSTGRES_USER=citystories
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ===== S3-compatible storage (Backblaze B2 for production) =====
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_ACCESS_KEY=your_b2_access_key
S3_SECRET_KEY=your_b2_secret_key
S3_BUCKET=city-stories

# ===== Claude API (Anthropic) =====
CLAUDE_API_KEY=sk-ant-...

# ===== ElevenLabs TTS API =====
ELEVENLABS_API_KEY=...

# ===== JWT Authentication =====
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ===== Domains =====
API_DOMAIN=api.yourdomain.com
ADMIN_DOMAIN=admin.yourdomain.com
ACME_EMAIL=your-email@yourdomain.com

# ===== CORS =====
ALLOWED_ORIGINS=https://admin.yourdomain.com
