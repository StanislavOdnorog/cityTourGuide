# PostgreSQL
POSTGRES_DB=citystories
POSTGRES_USER=citystories
POSTGRES_PASSWORD=citystories_secret
POSTGRES_PORT=5432

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Backup (used by infra/backup/backup.sh)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_secret
S3_BUCKET=city-stories
BACKUP_S3_PREFIX=backups
BACKUP_DAILY_RETAIN=7
BACKUP_WEEKLY_RETAIN=4
