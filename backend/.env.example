# Provider mode: "real" (default) uses live external services;
# "mock" uses in-process fakes for Claude, ElevenLabs, and S3.
# Mock mode lets contributors run locally without API credentials.
PROVIDER_MODE=real

# Logging
LOG_LEVEL=info  # debug, info, warn, error

# Server
PORT=8080
GIN_MODE=debug  # debug, release, test
ALLOWED_ORIGINS=http://localhost:5173
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=30s

# Database (required)
DATABASE_URL=postgres://citystories:citystories_secret@localhost:5433/citystories?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=5m
DB_HEALTH_CHECK_PERIOD=30s

# JWT authentication (required)
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# OAuth integrations
# Google Sign-In is optional. If enabled, provide GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=
#
# Apple Sign-In is optional. If enabled, provide the full set together:
# APPLE_CLIENT_ID, APPLE_TEAM_ID, APPLE_KEY_ID, APPLE_PRIVATE_KEY
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Firebase Cloud Messaging (optional)
# Provide the Firebase service account JSON as a single-line raw JSON string.
FCM_CREDENTIALS_JSON=
FCM_HTTP_TIMEOUT=30s         # Go duration; default 30s

# Worker integrations
# Claude is used by the worker for story generation.
CLAUDE_API_KEY=
CLAUDE_HTTP_TIMEOUT=60s      # Go duration; default 60s
#
# ElevenLabs is used by the worker for audio generation.
ELEVENLABS_API_KEY=
ELEVENLABS_HTTP_TIMEOUT=120s # Go duration; default 120s
#
# S3-compatible storage is required by the worker. Supply the full set together:
# S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY, S3_BUCKET
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_secret
S3_BUCKET=city-stories
