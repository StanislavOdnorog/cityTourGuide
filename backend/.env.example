# Server
PORT=8080
GIN_MODE=debug  # debug, release, test

# Database (required)
DATABASE_URL=postgres://citystories:citystories_secret@localhost:5433/citystories?sslmode=disable

# S3-compatible storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_secret
S3_BUCKET=city-stories

# Claude API (Anthropic)
CLAUDE_API_KEY=

# ElevenLabs TTS API
ELEVENLABS_API_KEY=

# JWT Authentication (required: JWT_SECRET)
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_TTL=900      # seconds (default: 15 minutes)
JWT_REFRESH_TTL=604800  # seconds (default: 7 days)
